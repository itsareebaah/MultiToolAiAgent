# Default provider: grok (Groq gsk_) | xai | openai | gemini | deepseek | ollama
AI_PROVIDER=grok

# --- Groq / Grok (gsk_ key) — https://console.groq.com ---
GROK_API_KEY=gsk_your-key-here
# GROQ_API_KEY=              # optional alias

# --- Grok xAI (xai- key only) — https://console.x.ai ---
# AI_PROVIDER=xai
# XAI_API_KEY=xai-your-key-here

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# GEMINI_API_KEY=your-gemini-key

# Email (SMTP) — optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your.email@gmail.com
